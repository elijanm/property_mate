# Copy to .env.local for local development overrides
# VITE_ prefix is required for values to be exposed to the browser bundle

# API base URL — leave empty to use the Vite dev proxy (default for local dev)
# Set to full URL only when the frontend is hosted on a different origin than the API
# Example for direct API access: VITE_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=

# Voice agent WebSocket URL (for browser-based sandbox calls)
# In production, update to your voice-agent's public WS URL
VITE_VOICE_AGENT_URL=ws://localhost:8010
VITE_IOT_API_BASE_URL=http://localhost:8020

# Calendly scheduling link — shown in the "Book a Demo" modal on the Pricing page
# Example: https://calendly.com/your-org/demo
VITE_CALENDLY_URL=
