# Application
APP_ENV=development
APP_VERSION=0.1.0
SECRET_KEY=change-me
LOG_LEVEL=INFO

# JWT (MUST match PMS backend — same secret so IoT validates the same tokens)
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=pms_iot
MONGO_MAX_POOL_SIZE=30

# Redis (separate DB from backend to avoid key collisions)
REDIS_URL=redis://localhost:6379/2

# RabbitMQ (shared instance with backend)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# S3 / MinIO (shared with backend — different key prefix)
S3_ENDPOINT_URL=http://localhost:9000
S3_PUBLIC_ENDPOINT_URL=
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=pms-iot
S3_REGION=us-east-1

# EMQX
EMQX_API_URL=http://localhost:18083
EMQX_API_KEY=                          # EMQX Dashboard API key
EMQX_API_SECRET=                       # EMQX Dashboard API secret
IOT_INTERNAL_SECRET=change-me-internal-secret  # shared with EMQX HTTP auth plugin

# MQTT (IoT service's own MQTT subscriber account on EMQX)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=iot-service
MQTT_PASSWORD=change-me-mqtt-password
MQTT_CLIENT_ID=iot-service-subscriber
MQTT_USE_TLS=false

# ThingsBoard
THINGSBOARD_URL=http://localhost:9090
THINGSBOARD_SYSADMIN_EMAIL=sysadmin@thingsboard.org
THINGSBOARD_SYSADMIN_PASSWORD=sysadmin   # CHANGE BEFORE PRODUCTION

# Headscale
HEADSCALE_URL=http://localhost:8085
HEADSCALE_API_KEY=                       # from: headscale apikeys create

# PMS Backend (for Tailscale proxy endpoint)
PMS_BACKEND_URL=http://localhost:8000/api/v1

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

RESEND_API_KEY=re_gcpvX4Di_8SQ3EyKGoPRiF7f9XfUUH2GN
EMAIL_FROM="Vibefluencer <campaigns@fileq.io>"                                                                                                                                                            
IOT_SERVICE_PUBLIC_URL=http://localhost:8020
