APP_NAME=PMS ML Service
HOST=0.0.0.0
PORT=8030
LOG_LEVEL=INFO

# MongoDB (separate database for ML data)
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DATABASE=pms_ml

# Redis (task queue + caching)
REDIS_URL=redis://redis:6379

# MLflow (backend store: SQLite in /mlflow volume; artifacts: MinIO S3)
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_DEFAULT_EXPERIMENT=pms-models

# S3 / MinIO (model artifacts + training data)
S3_ENDPOINT_URL=http://minio:9000          # internal URL used by the ML service container
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000  # URL reachable FROM RunPod pods (must be a public IP/hostname)
                                              # For local dev with RunPod: set to http://<your-public-ip>:9000
                                              # or use AWS S3/Cloudflare R2 (leave S3_ENDPOINT_URL blank for AWS)
                                              # NOTE: if this URL is unreachable from pods, small models (≤4MB)
                                              # are automatically recovered from pod stdout as a fallback.
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=pms-ml
S3_REGION=us-east-1

# PMS Backend (optional — for org/tenant context on inference)
PMS_API_URL=http://backend:8000/api/v1
PMS_SERVICE_TOKEN=

# Training hardware
CUDA_DEVICE=auto          # auto | cpu | cuda | cuda:0 | cuda:1
TRAINING_WORKERS=4
TRAINING_BATCH_SIZE=32
TRAINING_FP16=false
TRAINING_MAX_EPOCHS=100
TRAINING_EARLY_STOPPING=true
TRAINING_EARLY_STOPPING_PATIENCE=5

# Trainer plugin directory (mounted volume with user trainer .py files)
TRAINER_PLUGIN_DIR=/app/trainers

#Roboflow
ROBOFLOW_API_KEY=JNanrjzyuPkvjDTwvQyV

#admin@pms-ml.local / Admin@123456

# RunPod                                                                                                                                                                                                    
RUNPOD_API_KEY=your_openai_api_key_here                                                                                                                                                                                                                                                                                                                                                                          
RUNPOD_GPU_TYPE=NVIDIA GeForce RTX 3090   # or "NVIDIA A4000", "NVIDIA A100" etc.                                                                                                                           
RUNPOD_CONTAINER_DISK_GB=20                                                                                                                                                                                      
                                                                                                                                                                                                            
# Lambda Labs                                                                                                                                                                                               
LAMBDA_LABS_API_KEY=...                                                                                                                                                                                     
LAMBDA_LABS_SSH_KEY_NAME=...                                                                                                                                                                                
                                                        
# Modal                                                                                                                                                                                                     
MODAL_TOKEN_ID=...
MODAL_TOKEN_SECRET=...                                                                                                                                                                                      
MODAL_APP_ID=...  