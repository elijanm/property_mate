# ── Service ───────────────────────────────────────────────────────────────────
APP_NAME=PMS Voice Agent
HOST=0.0.0.0
PORT=8010
# Your publicly reachable URL (Telnyx needs to connect to /ws/media/*)
# Use ngrok for local dev: ngrok http 8010
PUBLIC_BASE_URL=https://your-ngrok-or-domain.example.com
LOG_LEVEL=INFO

# ── MongoDB (shared with backend) ─────────────────────────────────────────────
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DATABASE=pms

# ── Redis (shared with backend) ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Telnyx ────────────────────────────────────────────────────────────────────
TELNYX_API_KEY=KEY0123456789abcdef...
TELNYX_WEBHOOK_SECRET=your_webhook_secret
TELNYX_PHONE_NUMBER=+12025551234
TELNYX_CONNECTION_ID=your_call_control_application_id

# ── STT — Deepgram ────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=2de5f422dfaa31c2988859c4e36a1978526142d2
DEEPGRAM_STT_MODEL=nova-2-phonecall
DEEPGRAM_STT_LANGUAGE=en

# ── LLM (choose one provider) ────────────────────────────────────────────────
# Provider options: openai | anthropic | openai_compatible
LLM_PROVIDER=openai
LLM_API_KEY=api_key
LLM_MODEL=gpt-4o
LLM_BASE_URL=           # only for openai_compatible (e.g. http://ollama:11434/v1)
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ── TTS (choose one provider) ────────────────────────────────────────────────
# Provider options: openai | elevenlabs | deepgram
TTS_PROVIDER=openai
# OpenAI TTS
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_MODEL=tts-1
# ElevenLabs TTS (if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=api_key
ELEVENLABS_VOICE_ID=uju3wxzG5OhpWcoi3SMy
ELEVENLABS_MODEL=eleven_turbo_v2_5
# Deepgram TTS (if TTS_PROVIDER=deepgram)
DEEPGRAM_TTS_VOICE=aura-asteria-en

# ── PMS Backend ───────────────────────────────────────────────────────────────
PMS_API_URL=http://backend:8000/api/v1
# A superadmin JWT or long-lived service token from the PMS backend
PMS_SERVICE_TOKEN=token_key

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000           # internal Docker URL used for upload/sign
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000 # public URL rewritten into presigned links for browsers
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=pms-voice
S3_REGION=us-east-1

# ── Agent behaviour ───────────────────────────────────────────────────────────
COMPANY_NAME=Acme Properties
AGENT_NAME=Alex
DEFAULT_ORG_ID=           # fallback org_id when caller is not a known tenant
RECORDING_ENABLED=true
# false = staff get popup and decide; true = AI auto-answers all calls
AUTO_MODE_DEFAULT=false
