# Copy to .env and fill in production values

# Application
APP_ENV=development
APP_VERSION=0.1.0
SECRET_KEY=change-me-at-least-32-chars
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=pms

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# OpenSearch
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=Admin@1234
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false

# S3 / MinIO
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=pms-media
S3_REGION=us-east-1
S3_PRESIGNED_URL_EXPIRES=86400  # seconds; default 24 h

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Logging
LOG_LEVEL=INFO

# Observability
OTEL_SERVICE_NAME=pms-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ML Service — public URLs (override for production)
ML_APP_BASE_URL=https://api.mldock.io        # or https://www.mldock.io
ML_FRONTEND_BASE_URL=https://www.mldock.io   # used in verification email links
ML_RESEND_API_KEY=
ML_EMAIL_FROM=MLDock.io <noreply@mldock.io>

MINIO_API_CORS_ALLOW_ORIGIN=*
DISPOSABLE_EMAIL_CHECK_URL=http://ml-service:8030/api/v1/inference/kreateyou/throwaway_email_detector
DISPOSABLE_EMAIL_API_KEY=<>
# ── Split sandbox mode ────────────────────────────────────────────────────────
# false (default) = current behaviour (TRAINER_SANDBOX controls everything)
# true            = editor Test runs → sandbox-test cluster (fixture data, free)
#                   production Train → sandbox-prod-cpu cluster (real data)
SANDBOX_SPLIT_MODE=false

# To start split-sandbox services:
#   docker-compose --profile split-sandbox up -d sandbox-test sandbox-prod-cpu
#
# To scale test sandbox horizontally:
#   docker-compose --profile split-sandbox up -d --scale sandbox-test=3

# Test sandbox resource limits
SANDBOX_TEST_TIMEOUT=60
SANDBOX_TEST_MAX_CONCURRENT=5

# Production CPU sandbox resource limits
SANDBOX_PROD_CPU_TIMEOUT=28800
SANDBOX_PROD_CPU_MAX_CONCURRENT=2
SANDBOX_PROD_CPU_CPUS=4
SANDBOX_PROD_CPU_MEMORY=4g

# GPU pricing (charged from accelerated compute / general_balance)
SANDBOX_GPU_RATE_PER_HOUR=2.40

# Alertmanager SMTP (used for alert notifications)
ALERTMANAGER_SMTP_HOST=smtp.gmail.com:587
ALERTMANAGER_SMTP_FROM=alerts@yourdomain.com
ALERTMANAGER_SMTP_USER=alerts@yourdomain.com
ALERTMANAGER_SMTP_PASSWORD=your-app-password
ALERTMANAGER_EMAIL_TO=ops@yourdomain.com
