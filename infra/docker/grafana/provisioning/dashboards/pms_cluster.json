        { "expr": "rate(mongodb_ss_opcounters{legacy_op_type=\"update\"}[2m])", "refId": "C", "legendFormat": "Update" },
        { "expr": "rate(mongodb_ss_opcounters{legacy_op_type=\"delete\"}[2m])", "refId": "D", "legendFormat": "Delete" }
