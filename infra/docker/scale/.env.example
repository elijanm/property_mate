# ── MongoDB Replica Set ──────────────────────────────────────────────────────
MONGO_ROOT_USERNAME=pmsadmin
MONGO_ROOT_PASSWORD=change-me-strong-password
MONGO_REPLICA_SET=rs0
MONGO_DATABASE=pms

# Hostnames / IPs of each node as seen from the OTHER nodes
# Machine 1 (local) — set to your Cloudflare tunnel hostname
MONGO1_HOST=mongo.yourdomain.com
# Machine 2 (Linode VPS 1) — public IP
MONGO2_HOST=172.x.x.x
# Machine 3 (Linode VPS 2) — public IP
MONGO3_HOST=172.x.x.x

# Replica set connection string — used by all app services
MONGODB_URL=mongodb://${MONGO_ROOT_USERNAME}:${MONGO_ROOT_PASSWORD}@mongo1:27017,${MONGO2_HOST}:27017,${MONGO3_HOST}:27017/${MONGO_DATABASE}?replicaSet=${MONGO_REPLICA_SET}&authSource=admin

# ── Cloudflare Tunnel (Machine 1 only) ───────────────────────────────────────
# Get this from: cloudflared tunnel create pms-mongo → copy the token
CLOUDFLARE_TUNNEL_TOKEN=eyJ...your-tunnel-token-here

# ── App Services (same as existing .env) ─────────────────────────────────────
RESEND_API_KEY=
ML_RESEND_API_KEY=
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
ML_APP_BASE_URL=http://localhost:8030
ML_FRONTEND_BASE_URL=https://localhost:5443
ROBOFLOW_API_KEY=
