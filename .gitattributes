# Force LF line endings for shell scripts copied into Linux containers
# Without this, Windows git may convert \n → \r\n, breaking bash shebangs
*.sh        text eol=lf
*.bash      text eol=lf
Dockerfile* text eol=lf
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.env*      text eol=lf
*.conf      text eol=lf
*.toml      text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.pdf   binary
*.whl   binary
*.zip   binary
